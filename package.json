{
  "name": "lockstep",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5175",
    "build": "tsc -b && vite build",
    "setup": "node scripts/setup-binaries.mjs",
    "tauri": "tauri",
    "test:js": "vitest run",
    "test:rs": "cargo test --manifest-path src-tauri/Cargo.toml --target-dir src-tauri/target-test",
    "test:watch": "vitest",
    "test:heavy": "cargo test --manifest-path src-tauri/Cargo.toml --target-dir src-tauri/target-test -- --ignored",
    "test": "npm run test:js && npm run test:rs",
    "behaviors": "tsx scripts/behavior.ts check",
    "behaviors:check": "tsx scripts/behavior.ts check",
    "behaviors:audit": "tsx scripts/behavior.ts audit",
    "layouts": "tsx scripts/layouts.ts check",
    "layouts:check": "tsx scripts/layouts.ts check",
    "spec:check": "npm run behaviors:check && npm run layouts:check",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@amiceli/vitest-cucumber": "^6.3.0",
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "happy-dom": "^20.9.0",
    "tsx": "^4.19.3",
    "typescript": "~5.9.3",
    "vite": "^8.0.5",
    "vitest": "^4.1.4",
    "yaml": "^2.8.3"
  }
}
