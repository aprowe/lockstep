{
  "name": "lockstep",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite --port 5175",
    "build": "tsc -b && vite build",
    "setup": "node scripts/setup-binaries.mjs",
    "tauri": "tauri",
    "check": "npm run behaviors && npm run layouts && vitest run",
    "test": "vitest run",
    "test:watch": "vitest",
    "behaviors": "tsx scripts/behavior.ts check",
    "layouts": "tsx scripts/layouts.ts check",
    "prepare": "git config core.hooksPath .githooks"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.11.2",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-dialog": "^2.7.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-redux": "^9.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@testing-library/react": "^16.3.2",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "esbuild": "^0.28.0",
    "happy-dom": "^20.9.0",
    "tsx": "^4.19.3",
    "typescript": "~5.9.3",
    "vite": "^8.0.5",
    "vitest": "^4.1.4",
    "yaml": "^2.8.3"
  }
}
