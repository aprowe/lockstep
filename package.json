{
    "name": "lockstep",
    "private": true,
    "version": "0.3.2",
    "type": "module",
    "scripts": {
        "dev": "vite --port 5175",
        "build": "tsc --noEmit && vite build",
        "setup": "node scripts/setup-binaries.mjs",
        "tauri": "tauri",
        "test": "npm run test:unit && npm run test:rs",
        "test:unit": "vitest run",
        "test:unit:watch": "vitest",
        "test:rs": "cargo test --manifest-path src-tauri/Cargo.toml --target-dir src-tauri/target-test",
        "test:rs:heavy": "cargo test --manifest-path src-tauri/Cargo.toml --target-dir src-tauri/target-test -- --ignored",
        "screenshots": "playwright test --config playwright.screenshots.config.ts",
        "playwright:install": "playwright install chromium",
        "behaviors": "tsx scripts/behavior.ts check",
        "behaviors:audit": "tsx scripts/behavior.ts audit",
        "layouts": "tsx scripts/layouts.ts check",
        "spec:check": "npm run behaviors && npm run layouts",
        "lint": "eslint .",
        "lint:fix": "eslint . --fix",
        "format": "prettier --write .",
        "format:check": "prettier --check .",
        "prepare": "git config core.hooksPath .githooks"
    },
    "dependencies": {
        "@reduxjs/toolkit": "^2.11.2",
        "@tauri-apps/api": "^2.10.1",
        "@tauri-apps/plugin-dialog": "^2.7.0",
        "@tauri-apps/plugin-opener": "^2.5.3",
        "dockview-react": "^5.2.0",
        "es-toolkit": "^1.46.1",
        "react": "^19.2.4",
        "react-dom": "^19.2.4",
        "react-redux": "^9.2.0"
    },
    "devDependencies": {
        "@amiceli/vitest-cucumber": "^6.3.0",
        "@eslint/js": "^9.39.4",
        "@playwright/test": "^1.59.1",
        "@tauri-apps/cli": "^2.10.1",
        "@testing-library/react": "^16.3.2",
        "@types/node": "^25.6.0",
        "@types/react": "^19.2.14",
        "@types/react-dom": "^19.2.3",
        "@vitejs/plugin-react": "^6.0.1",
        "esbuild": "^0.28.0",
        "eslint": "^9.39.4",
        "eslint-config-prettier": "^10.1.8",
        "eslint-plugin-react": "^7.37.5",
        "eslint-plugin-react-hooks": "^7.1.1",
        "eslint-plugin-react-refresh": "^0.5.2",
        "happy-dom": "^20.9.0",
        "prettier": "^3.8.3",
        "tsx": "^4.19.3",
        "typescript": "~5.9.3",
        "typescript-eslint": "^8.59.4",
        "vite": "^8.0.5",
        "vitest": "^4.1.4",
        "yaml": "^2.8.3"
    }
}
