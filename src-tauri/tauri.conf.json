{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Lockstep",
  "version": "0.3.0",
  "identifier": "com.vjtools.toolkit",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5175",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Lockstep",
        "width": 1400,
        "height": 900,
        "minWidth": 900,
        "minHeight": 600,
        "dragDropEnabled": false,
        "decorations": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "externalBin": ["binaries/ffmpeg", "binaries/ffprobe", "binaries/rife-ncnn-vulkan"],
    "resources": {
      "binaries/rife-v4.6/*": "rife-v4.6/"
    }
  },
  "plugins": {}
}
