#!/bin/sh
set -e

# Fast checks first so style/lint failures surface before the slow suites.
echo "▶ prettier"
npx prettier --check . --log-level warn

echo "▶ eslint"
npm run lint --silent

echo "▶ tests"
npm test --silent

echo "▶ behavior coverage"
npm run behaviors --silent

echo "▶ layout coverage"
npm run layouts --silent
